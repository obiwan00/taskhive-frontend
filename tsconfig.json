/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve",
    "paths": {
      "@core/models": ["./src/app/core/models/index.ts"],
      "@core/utils": ["./src/app/core/utils/index.ts"],
      "@core/pipe": ["./src/app/core/pipes/index.ts"],
      "@shared/components": ["./src/app/shared/components/index.ts"],
      "@shared/directives": ["./src/app/shared/directives/index.ts"],
      "@shared/pipes": ["./src/app/shared/pipes/index.ts"],
      "@shared/utils": ["./src/app/shared/utils/index.ts"],
      "@features/projects": ["./src/app/features/projects/index.ts"],
      "@features/my-tickets": ["./src/app/features/my-tickets/index.ts"],
      "@features/auth": ["./src/app/features/auth/index.ts"],
      "@features/profile": ["./src/app/features/profile/index.ts"],
      "@permissions": ["./src/app/features/permissions/index.ts"],
      "@layouts": ["./src/app/layouts/index.ts"],
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  },
  "files": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.spec.json"
    }
  ]
}
